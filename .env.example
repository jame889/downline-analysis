# Generate with: openssl rand -base64 48
JWT_SECRET=

# Server-side administrator member ID. Do not use NEXT_PUBLIC_*.
ROOT_MEMBER_ID=

# Absolute path or mounted volume outside this Git repository.
PRIVATE_DATA_DIR=/var/lib/first-community

# Enable only during a short password migration window.
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false

# Protect scheduled endpoints.
CRON_SECRET=
TELEGRAM_BOT_TOKEN=

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Server-side Supabase credentials. Never expose the service-role key to clients.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Create this as a private Supabase Storage bucket in production.
# When Supabase is not configured, profiles are stored under PRIVATE_DATA_DIR/personality.
PERSONALITY_BUCKET=personality-profiles
