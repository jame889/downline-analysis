# JWT Secret (ใช้สร้าง session token)
JWT_SECRET=your-secret-key-here

# Telegram Bot Token (จาก @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Cron Secret (ป้องกัน /api/cron/* ถูกเรียกจากภายนอก)
# ตั้งค่าเดียวกันทั้ง Vercel dashboard และ vercel.json header
CRON_SECRET=your-cron-secret-here

# Coach JOE cloud AI. Configure at least one provider.
# Provider order: Groq -> OpenRouter -> Cloudflare -> Coach Data Engine.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/qwen/qwen3-30b-a3b-fp8
AI_TIMEOUT_MS=22000
AI_MAX_TOKENS=650
