# Production Environment Variables
# Copy these to Railway dashboard → Variables

# REQUIRED - เปลี่ยนเป็น random string ยาวๆ
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS

# REQUIRED - รหัสสมาชิก Admin หลัก
NEXT_PUBLIC_ROOT_MEMBER_ID=900057

# OPTIONAL - Telegram Bot
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Railway จะ set PORT อัตโนมัติ
# PORT=3000
